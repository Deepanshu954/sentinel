# Sentinel .gitignore

# ── Build artifacts ──────────────────────────────────
target/
*.class
*.jar
!orchestrator/target/orchestrator-*.jar

# ── Python ───────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
*.egg-info/
dist/
build/

# ── ML models (large binaries, re-trainable) ────────
ml-service/models/*.json
ml-service/models/*.pkl
ml-service/data/*.parquet
ml-service/libomp.tar.gz

# ── Environment ──────────────────────────────────────
.env
sentinel.env
myenv
!.env.example

# ── Python ───────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
myenv/
*.egg-info/
dist/
build/
*.log

# ── Validation / test outputs ────────────────────────
validation_*.txt
train_log.txt
e2e_test_log.txt
e2e_report.md
orchestrator.log
*.log

# ── Temp & OS files ──────────────────────────────────
/tmp/
*.tmp
.DS_Store
Thumbs.db

# ── IDE ──────────────────────────────────────────────
.vscode/
.idea/
*.iml
*.swp
*.swo
*~

# ── Docker ───────────────────────────────────────────
docker-compose.override.yml

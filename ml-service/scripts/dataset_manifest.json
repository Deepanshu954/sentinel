{
  "description": "Sentinel multi-source dataset manifest. Enable sources you have staged locally. Each source must expose timestamp + numeric value columns.",
  "fusion_mode": "sum",
  "synthetic_fallback": true,
  "synthetic_seed": 42,
  "output_path": "ml-service/data/processed/training_data.parquet",
  "quality_report_path": "ml-service/data/processed/dataset_quality_report.json",
  "sources": [
    {
      "name": "wikimedia_pageviews",
      "enabled": false,
      "adapter": "wikimedia",
      "path": "ml-service/data/raw/wikimedia_pageviews.csv",
      "timestamp_col": "timestamp",
      "value_col": "views",
      "resample": "1min",
      "agg": "sum",
      "multiplier": 1.0,
      "weight": 1.0,
      "timezone": "UTC",
      "filter_start": null,
      "filter_end": null,
      "clip_min": 0.0,
      "clip_max": null,
      "missing_data_policy": "interpolate"
    },
    {
      "name": "wikimedia_hourly_dump",
      "enabled": true,
      "adapter": "wikimedia",
      "path": "ml-service/data/raw/pageviews-20240101-000000.gz",
      "timestamp_col": "timestamp",
      "value_col": "views",
      "resample": "1min",
      "agg": "sum",
      "multiplier": 1.0,
      "weight": 1.0,
      "timezone": "UTC",
      "filter_start": null,
      "filter_end": null,
      "clip_min": 0.0,
      "clip_max": null,
      "missing_data_policy": "interpolate"
    },
    {
      "name": "nasa_http_jul95",
      "enabled": true,
      "adapter": "apache_access",
      "path": "ml-service/data/raw/NASA_access_log_Jul95.gz",
      "timestamp_col": "timestamp",
      "value_col": "value",
      "resample": "1min",
      "agg": "sum",
      "multiplier": 1.0,
      "weight": 1.3,
      "timezone": "UTC",
      "filter_start": null,
      "filter_end": null,
      "clip_min": 0.0,
      "clip_max": null,
      "missing_data_policy": "interpolate"
    },
    {
      "name": "nasa_http_aug95",
      "enabled": true,
      "adapter": "apache_access",
      "path": "ml-service/data/raw/NASA_access_log_Aug95.gz",
      "timestamp_col": "timestamp",
      "value_col": "value",
      "resample": "1min",
      "agg": "sum",
      "multiplier": 1.0,
      "weight": 1.3,
      "timezone": "UTC",
      "filter_start": null,
      "filter_end": null,
      "clip_min": 0.0,
      "clip_max": null,
      "missing_data_policy": "interpolate"
    },
    {
      "name": "azure_functions_2019",
      "enabled": false,
      "adapter": "azure_functions",
      "path": "ml-service/data/raw/azure_functions_invocations.csv",
      "timestamp_col": "end_timestamp",
      "value_col": "invocations",
      "resample": "1min",
      "agg": "sum",
      "multiplier": 1.0,
      "weight": 1.5,
      "timezone": "UTC",
      "filter_start": null,
      "filter_end": null,
      "clip_min": 0.0,
      "clip_max": null,
      "missing_data_policy": "interpolate"
    },
    {
      "name": "azure_vm_v2",
      "enabled": false,
      "adapter": "azure_vm",
      "path": "ml-service/data/raw/azure_vm_v2.csv",
      "timestamp_col": "timestamp_vm",
      "value_col": "avg_cpu",
      "resample": "1min",
      "agg": "mean",
      "multiplier": 1500.0,
      "weight": 1.0,
      "timezone": "UTC",
      "filter_start": null,
      "filter_end": null,
      "clip_min": 0.0,
      "clip_max": null,
      "missing_data_policy": "interpolate"
    },
    {
      "name": "google_cluster_2019",
      "enabled": false,
      "adapter": "google_cluster",
      "path": "ml-service/data/raw/google_cluster_2019.csv",
      "timestamp_col": "start_time",
      "value_col": "avg_cpu",
      "resample": "1min",
      "agg": "mean",
      "multiplier": 2000.0,
      "weight": 1.2,
      "timezone": "UTC",
      "filter_start": null,
      "filter_end": null,
      "clip_min": 0.0,
      "clip_max": null,
      "missing_data_policy": "interpolate"
    },
    {
      "name": "alibaba_cluster_2018",
      "enabled": false,
      "adapter": "alibaba",
      "path": "ml-service/data/raw/alibaba_cluster_2018.csv",
      "timestamp_col": "time_stamp",
      "value_col": "cpu_util_percent",
      "resample": "1min",
      "agg": "mean",
      "multiplier": 1.0,
      "weight": 1.0,
      "timezone": "UTC",
      "filter_start": null,
      "filter_end": null,
      "clip_min": 0.0,
      "clip_max": null,
      "missing_data_policy": "drop"
    },
    {
      "name": "legacy_synthetic",
      "enabled": true,
      "adapter": "generic",
      "path": "ml-service/data/raw/_synthetic_placeholder_.csv",
      "timestamp_col": "timestamp",
      "value_col": "value",
      "resample": "1min",
      "agg": "sum",
      "multiplier": 1.0,
      "weight": 1.0,
      "timezone": "UTC",
      "filter_start": null,
      "filter_end": null,
      "clip_min": 0.0,
      "clip_max": null,
      "missing_data_policy": "drop"
    }
  ]
}

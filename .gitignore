# ─── Environment ──────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Go ───────────────────────────────────────────────────────────────────────
gateway/gateway
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/

# ─── Java / Maven ─────────────────────────────────────────────────────────────
orchestrator/target/
*.class
*.jar
*.war
*.ear
*.log
*.ctxt
.mtj.tmp/
hs_err_pid*
replay_pid*
.idea/
*.iml
*.ipr
*.iws

# ─── Python ───────────────────────────────────────────────────────────────────
ml-service/__pycache__/
ml-service/*.pyc
ml-service/.mypy_cache/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/
venv/
.pytest_cache/

# ─── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Data / Models / Outputs ──────────────────────────────────────────────────
# Ignore huge datasets and training checkpoints
data/
ml-service/data/*.parquet

# Ignore local testing logs and temporary SIP sandbox folders
test_outputs.log
e2e_test_log.txt
.gotmp/
.tmp/
.jvmtmp/

# Standard model ignores
*.model
*.h5
*.pkl

# EXCEPTION: We MUST commit the production `.pkl` and `.json` models 
# inside ml-service/models/ so the Dockerfile can successfully COPY them!
!ml-service/models/*.pkl
!ml-service/models/*.json
